---
const { title = "Grimwell Studio", description = "Publishing the Ævyndal RPG campaign setting and producing live immersive experiences." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/global.css" />
  </head>
  <body>
    <main class="wrap">
      <slot />
      <footer class="footer">
        <span>© {new Date().getFullYear()} Grimwell Studio</span>
      </footer>
    </main>
  </body>
</html>
