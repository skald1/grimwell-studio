---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ProductionPanel from "../components/ProductionPanel.astro";
import Newsletter from "../components/Newsletter.astro";
import "../styles/global.css";

const upcomingCards = [
  {
    title: "The Returned",
    image: "/images/TheReturnedPoster.jpg",
  },
];

const developingCards = [
  {
    title: "Create a Character",
    image: "/images/Fragments.jpg",
  },
  {
    title: "The Returned",
    image: "/images/ZeroRebels.jpg",
  },
  {
    title: "Stories & Fiction",
    image: "/images/Stillness.jpg",
  },
  {
    title: "For Game Masters",
    image: "/images/UntimelyHeroes13thHour.jpg",
  },
];

const twitchUrl = "https://twitch.tv/grimwellstudio";
---

<BaseLayout>
  <main class="page-shell">
    <header class="site-header">
      <a class="brand" href="#">
        <img src="/images/GrimwellHimselfWhite200.webp" alt="" aria-hidden="true" />
        <span>GRIMWELL STUDIO</span>
      </a>
      <nav aria-label="Primary">
        <a href="#explore">Ævyndal</a>
        <a href="#setting">Setting</a>
        <a href="#newsletter">Newsletter</a>
      </nav>
    </header>

    <div class="snap-scroll">
      <section id="explore" class="snap-fold intro-fold" aria-labelledby="explore-title">
        <Hero />

        <section class="card-section" aria-label="Choose where to begin">
          <a class="card-section__header" href={twitchUrl} rel="noopener">
            Playing Soon...
          </a>

          <div class="card-groups">
            <div class="card-group card-group--upcoming" aria-label="Upcoming">
              <p class="card-group__label">Upcoming</p>
              <div class="card-grid card-grid--single">
                {upcomingCards.map((card) => (
                  <button
                    type="button"
                    class="world-card"
                    aria-label={`Open ${card.title} poster`}
                    data-lightbox-trigger
                    data-lightbox-image={card.image}
                    data-lightbox-title={card.title}
                  >
                    <img src={card.image} alt="" aria-hidden="true" />
                  </button>
                ))}
              </div>
            </div>

            <div class="card-group card-group--developing" aria-label="Now developing">
              <p class="card-group__label">Now developing</p>
              <div class="card-grid card-grid--developing">
                {developingCards.map((card) => (
                  <button
                    type="button"
                    class="world-card"
                    aria-label={`Open ${card.title} poster`}
                    data-lightbox-trigger
                    data-lightbox-image={card.image}
                    data-lightbox-title={card.title}
                  >
                    <img src={card.image} alt="" aria-hidden="true" />
                  </button>
                ))}
              </div>
            </div>
          </div>
        </section>
      </section>

        <ProductionPanel
          id="setting"
          status="ÆVYNDAL SETTING"
          title="A world built for stories at the table."
          description="Ævyndal is a living multiverse spanning eight ages, shaped for campaigns, fiction, and discovery. It is designed to give players places to belong, histories to uncover, and conflicts big enough to leave marks across time."
          format="Eight ages - GM-first setting tools - Story-driven play"
          image="/images/production-01.svg"
          cta="Visit Aevyndal"
          href="https://aevyndal.com"
        />

        <ProductionPanel
          status="IN DEVELOPMENT"
          title="Fragments"
          description="Five people wake in a world that seems to remember them better than they remember themselves."
          format="Serialized science-fantasy actual play"
          image="/images/production-02.svg"
          reverse={true}
          cta="Read the project note"
        />

        <ProductionPanel
          status="COMING NEXT"
          title="Untitled Grimwell Production"
          description="Placeholder copy for the next announced production, release, or major studio project."
          format="Format TBD"
          image="/images/production-03.svg"
          cta="See what's coming"
        />

        <ProductionPanel
          status="EARLY DEVELOPMENT"
          title="Project Blackglass"
          description="A deliberately spare placeholder for an experiment, prototype, or concept you are ready to tease but not promise."
          format="Experimental project"
          image="/images/production-04.svg"
          reverse={true}
          cta="View development notes"
        />

      <Newsletter />
    </div>

    <div class="lightbox" role="dialog" aria-modal="true" aria-label="Poster preview" hidden>
      <button class="lightbox__backdrop" type="button" aria-label="Close poster preview"></button>
      <div class="lightbox__content">
        <button class="lightbox__close" type="button" aria-label="Close poster preview">X</button>
        <img class="lightbox__image" src="" alt="" />
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const lightbox = document.querySelector(".lightbox");
  const lightboxImage = document.querySelector(".lightbox__image");
  const lightboxCloseControls = document.querySelectorAll(".lightbox__close, .lightbox__backdrop");
  const lightboxTriggers = document.querySelectorAll("[data-lightbox-trigger]");

  const closeLightbox = () => {
    if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;

    lightbox.hidden = true;
    lightboxImage.src = "";
    lightboxImage.alt = "";
  };

  lightboxTriggers.forEach((trigger) => {
    trigger.addEventListener("click", (event) => {
      if (!(trigger instanceof HTMLElement)) return;
      if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;
      if (!trigger.dataset.lightboxImage) return;

      event.preventDefault();
      lightboxImage.src = trigger.dataset.lightboxImage;
      lightboxImage.alt = trigger.dataset.lightboxTitle || "Poster preview";
      lightbox.hidden = false;
    });
  });

  lightboxCloseControls.forEach((control) => {
    control.addEventListener("click", closeLightbox);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeLightbox();
    }
  });
</script>
