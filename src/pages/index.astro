---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Newsletter from "../components/Newsletter.astro";
import TheReturnedTeaser from "../components/TheReturnedTeaser.astro";
import UntimelyHeroesTeaser from "../components/UntimelyHeroesTeaser.astro";
import "../styles/global.css";

const upcomingCards = [
  {
    title: "Untimely Heroes: The Thirteenth Hour",
    image: "/images/UntimelyHeroes13thHour.jpg",
    href: "#untimely-heroes",
  },
  {
    title: "The Returned",
    image: "/images/TheReturnedPoster.jpg",
    href: "#the-returned",
  },
];

const developingCards = [
  {
    title: "Create a Character",
    image: "/images/Fragments.jpg",
  },
  {
    title: "The Returned",
    image: "/images/ZeroRebels.jpg",
  },
  {
    title: "Stories & Fiction",
    image: "/images/Stillness.jpg",
  },
];

const twitchUrl = "https://twitch.tv/grimwellstudio";
---

<BaseLayout>
  <main class="page-shell">
    <header class="site-header">
      <a class="brand" href="#">
        <img src="/images/GrimwellHimselfWhite200.webp" alt="" aria-hidden="true" />
        <span>GRIMWELL STUDIO</span>
      </a>
      <nav aria-label="Primary">
        <a href="#explore">Home</a>
        <a href="#untimely-heroes">Untimely Heroes</a>
        <a href="#the-returned">The Returned</a>
        <a href="#newsletter">Newsletter</a>
      </nav>
    </header>

    <div class="snap-scroll">
      <section id="explore" class="snap-fold intro-fold" aria-labelledby="explore-title">
        <Hero />

        <section class="card-section" aria-label="Choose where to begin">
          <a class="card-section__header" href={twitchUrl} rel="noopener">
            Playing Soon...
          </a>

          <div class="card-groups">
            <div class="card-group card-group--upcoming" aria-label="In Production">
              <p class="card-group__label">In Production</p>
              <div class="card-grid card-grid--upcoming">
                {upcomingCards.map((card) => (
                  <a
                    href={card.href}
                    class="world-card"
                    aria-label={`Go to ${card.title}`}
                  >
                    <img src={card.image} alt="" aria-hidden="true" />
                  </a>
                ))}
              </div>
            </div>

            <div class="card-group card-group--developing" aria-label="Now developing">
              <p class="card-group__label">Now developing</p>
              <div class="card-grid card-grid--developing">
                {developingCards.map((card) => (
                  <button
                    type="button"
                    class="world-card"
                    aria-label={`Open ${card.title} poster`}
                    data-lightbox-trigger
                    data-lightbox-image={card.image}
                    data-lightbox-title={card.title}
                  >
                    <img src={card.image} alt="" aria-hidden="true" />
                  </button>
                ))}
              </div>
            </div>
          </div>
        </section>
      </section>

        <UntimelyHeroesTeaser />

        <TheReturnedTeaser />

      <Newsletter />
    </div>

    <div class="lightbox" role="dialog" aria-modal="true" aria-label="Poster preview" hidden>
      <button class="lightbox__backdrop" type="button" aria-label="Close poster preview"></button>
      <div class="lightbox__content">
        <button class="lightbox__close" type="button" aria-label="Close poster preview">X</button>
        <img class="lightbox__image" src="" alt="" />
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const lightbox = document.querySelector(".lightbox");
  const lightboxImage = document.querySelector(".lightbox__image");
  const lightboxCloseControls = document.querySelectorAll(".lightbox__close, .lightbox__backdrop");
  const lightboxTriggers = document.querySelectorAll("[data-lightbox-trigger]");

  const closeLightbox = () => {
    if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;

    lightbox.hidden = true;
    lightboxImage.src = "";
    lightboxImage.alt = "";
  };

  lightboxTriggers.forEach((trigger) => {
    trigger.addEventListener("click", (event) => {
      if (!(trigger instanceof HTMLElement)) return;
      if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;
      if (!trigger.dataset.lightboxImage) return;

      event.preventDefault();
      lightboxImage.src = trigger.dataset.lightboxImage;
      lightboxImage.alt = trigger.dataset.lightboxTitle || "Poster preview";
      lightbox.hidden = false;
    });
  });

  lightboxCloseControls.forEach((control) => {
    control.addEventListener("click", closeLightbox);
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeLightbox();
    }
  });

  const teaserSections = document.querySelectorAll(".untimely-teaser");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (!prefersReducedMotion.matches) {
    teaserSections.forEach((section) => {
      if (!(section instanceof HTMLElement)) return;

      let animationFrame = 0;

      const resetParallax = () => {
        section.style.setProperty("--teaser-parallax-x", "0px");
        section.style.setProperty("--teaser-parallax-y", "0px");
        section.style.setProperty("--teaser-light-x", "50%");
        section.style.setProperty("--teaser-light-y", "50%");
      };

      section.addEventListener("pointermove", (event) => {
        if (animationFrame) {
          window.cancelAnimationFrame(animationFrame);
        }

        animationFrame = window.requestAnimationFrame(() => {
          const bounds = section.getBoundingClientRect();
          const x = (event.clientX - bounds.left) / bounds.width - 0.5;
          const y = (event.clientY - bounds.top) / bounds.height - 0.5;
          const lightX = ((event.clientX - bounds.left) / bounds.width) * 100;
          const lightY = ((event.clientY - bounds.top) / bounds.height) * 100;

          section.style.setProperty("--teaser-parallax-x", `${x * 8}px`);
          section.style.setProperty("--teaser-parallax-y", `${y * 6}px`);
          section.style.setProperty("--teaser-light-x", `${lightX}%`);
          section.style.setProperty("--teaser-light-y", `${lightY}%`);
        });
      });

      section.addEventListener("pointerleave", resetParallax);
      section.addEventListener("blur", resetParallax, true);
    });
  }
</script>
