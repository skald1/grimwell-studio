---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Grimwell Studio";
const description = "Independent studio publishing the Ævyndal RPG campaign setting and producing live immersive experiences.";
---

<BaseLayout title={title} description={description}>
  <h1>Grimwell Studio</h1>
  <p class="muted">
    Independent studio publishing Ævyndal and producing live immersive experiences.
  </p>

  <div class="grid">
    <a class="card" href="https://aevyndal.com" rel="noopener">
      <h2>Ævyndal</h2>
      <p>GM-first setting tools, playable locations, and modular world content.</p>
    </a>

    <a class="card" href="/contact/">
      <h2>Contact</h2>
      <p>Collaboration, press, and production inquiries.</p>
    </a>
  </div>
</BaseLayout>
