---
interface Props {
  id?: string;
  status: string;
  title: string;
  description: string;
  format: string;
  image: string;
  cta: string;
  href?: string;
  reverse?: boolean;
}

const { id, status, title, description, format, image, cta, href = "#", reverse = false } = Astro.props;
---

<article id={id} class:list={["snap-fold", "production-panel", { "production-panel--reverse": reverse }]}>
  <img src={image} alt="" aria-hidden="true" />
  <div class="production-panel__body">
    <p class="eyebrow">{status}</p>
    <h3>{title}</h3>
    <p>{description}</p>
    <p class="production-panel__format">{format}</p>
    <a href={href}>{cta}</a>
  </div>
</article>
