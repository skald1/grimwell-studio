<section id="newsletter" class="snap-fold newsletter" aria-labelledby="newsletter-title">
  <div class="newsletter__inner">
    <p class="eyebrow">BUTTONDOWN NEWSLETTER</p>

    <h2 id="newsletter-title">
      Keep watch on what we're building.
    </h2>

    <p>
      Production updates, new Ævyndal material, casting news,
      development notes, and announcements from Grimwell Studio.
    </p>

    <form
      class="newsletter__form"
      action="https://buttondown.email/api/emails/embed-subscribe/sjvox"
      method="post"
      target="popupwindow"
    >
      <label class="sr-only" for="newsletter-email">
        Email address
      </label>

      <input
        id="newsletter-email"
        type="email"
        name="email"
        placeholder="you@example.com"
        required
      />

      <button type="submit">
        Join the list
      </button>
    </form>
  </div>
</section>
